# Supabase (public client-side)
# Create a Supabase project, then copy these from Project Settings → API
VITE_SUPABASE_URL=
VITE_SUPABASE_ANON_KEY=

# Optional: fixed access code required to use Coach Login/Signup UI.
# Set this in .env.local to prevent members from creating/logging into coach accounts.
VITE_COACH_ACCESS_CODE=
